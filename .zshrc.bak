
#
# .zshrc
#
# @author Scott Perkins
#

# --- Enable vi mode ---
set -o vi

## --- Keybindings for editing ---
bindkey "^H" backward-delete-char        # Ctrl-H / Backspace fixes
bindkey '^A' beginning-of-line           # Ctrl-A to go to start
bindkey '^E' end-of-line                 # Ctrl-E to go to end

## --- History search in vi-mode ---
bindkey -M vicmd '/' history-incremental-search-backward
bindkey -M vicmd '?' history-incremental-search-forward

# History configuration
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt INC_APPEND_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_SPACE

# Useful zsh options
setopt AUTO_CD              # cd by typing directory name
setopt CORRECT              # command correction
setopt GLOB_DOTS            # include dotfiles in globbing
#.config/dotfiles
[[ -f ~/.config/dotfiles/zsh/aliases.zsh ]] && source ~/.config/dotfiles/zsh/aliases.zsh
[[ -f ~/.config/dotfiles/zsh/starship.zsh ]] && source ~/.config/dotfiles/zsh/starship.zsh
#[[ -f ~/.zsh/goto.zsh ]] && source ~/.zsh/goto.zsh

eval "$(starship init zsh)"
# You may need to manually set your language environment
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export FUNNEST=750


# fzf keybind for interactive history search
#if [ -f ~/.fzf.zsh ]; then
#  source ~/.fzf.zsh
#fi

#fzf-tab
autoload -Uz compinit
compinit
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
# fzf-tab
source $(brew --prefix)/opt/fzf-tab/
##########


test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh" || true

#================================#
# Force emacs-style bindings (Ghostty expects this)
#bindkey -e

